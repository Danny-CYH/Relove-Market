{
    "compilerOptions": {
        // ✅ Allow both JS and TS files
        "allowJs": true,
        "jsx": "react-jsx",

        // ✅ Module settings
        "module": "esnext",
        "moduleResolution": "node",
        "target": "es2015",
        "lib": ["dom", "dom.iterable", "esnext"],

        // ✅ Import settings
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,

        // ✅ Path aliases (if you use @/)
        "baseUrl": ".",
        "paths": {
            "@/*": ["./resources/js/*"],
            "@/Components/*": ["./resources/js/Components/*"]
        },

        // ✅ Type checking (start loose, get stricter over time)
        "strict": false,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
        "isolatedModules": true,

        // ✅ Include ALL your files
        "include": [
            "resources/js/**/*",
            "resources/js/**/*.js",
            "resources/js/**/*.jsx",
            "resources/js/**/*.ts",
            "resources/js/**/*.tsx"
        ],
        "exclude": ["node_modules", "public", "vendor"]
    }
}
